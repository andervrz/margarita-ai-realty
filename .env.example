# .env.example
# ==============================================================
# Margarita AI Realty — Variables de Entorno
# Versión: 1.2.0
#
# INSTRUCCIONES:
#   1. Copia este archivo: cp .env.example .env
#   2. Rellena los valores marcados con  ← REQUERIDO
#   3. Nunca commitees .env al repositorio
#   4. .env está en .gitignore
# ==============================================================


# ── App ────────────────────────────────────────────────────────
APP_ENV=development              # development | production | testing
APP_NAME="Margarita AI Realty"
SECRET_KEY=                      # ← REQUERIDO — openssl rand -hex 32
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR


# ── Base de Datos ──────────────────────────────────────────────
# Dev: SQLite con WAL mode (stack unificado SQLite + sqlite-vec)
DATABASE_URL=sqlite+aiosqlite:///./chatbot.db

# Producción: PostgreSQL + pgvector (mismo ORM, solo cambiar URL)
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/margarita_realty


# ── Embeddings (sentence-transformers) ────────────────────────
# Modelo multilingüe ES/EN — primera ejecución descarga ~120MB
# Modelo alternativo más ligero: paraphrase-MiniLM-L6-v2 (384 dims también)
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DIMS=384               # Debe coincidir con el modelo elegido


# ── LLM — LiteLLM los lee automáticamente con estos nombres ───
GROQ_API_KEY=                    # ← REQUERIDO — console.groq.com (gratis)
GEMINI_API_KEY=                  # Fallback V1 — aistudio.google.com (gratis)
# MISTRAL_API_KEY=               # Diferido a V2


# ── Email SMTP ─────────────────────────────────────────────────
# Gmail: habilitar "App Passwords" en cuenta Google
# (Seguridad → Verificación en 2 pasos → Contraseñas de aplicación)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=                       # ← tu@gmail.com
SMTP_PASSWORD=                   # ← App password (16 caracteres, NO tu contraseña normal)
SMTP_FROM_NAME="Chatbot Inmobiliario Margarita"


# ── WhatsApp Meta Cloud API ────────────────────────────────────
# Panel: developers.facebook.com → Tu app → WhatsApp → API Setup
WHATSAPP_TOKEN=                  # Token permanente de Meta Business
WHATSAPP_API_VERSION=v18.0       # Versión de la API de WhatsApp


# ── Google Calendar ────────────────────────────────────────────
# Requiere Service Account con permiso de Calendar
# Guía: https://developers.google.com/calendar/api/quickstart/python
GOOGLE_CALENDAR_CREDENTIALS_PATH=./credentials.json   # Service account JSON
GOOGLE_CALENDAR_TIMEZONE=America/Caracas


# ── Timeouts (segundos) ────────────────────────────────────────
LLM_TIMEOUT=30                   # Timeout por llamada al LLM
EXTERNAL_API_TIMEOUT=15          # Timeout para WhatsApp / Calendar
WEBSOCKET_HEARTBEAT_INTERVAL=30  # Ping cada N segundos


# ── Memoria & Contexto ─────────────────────────────────────────
SESSION_TTL_MINUTES=30                  # Sesiones inactivas expiran tras N minutos
SESSION_CLEANUP_INTERVAL_SECONDS=300    # Background task limpia sesiones cada 5 min
MAX_MESSAGES_IN_CONTEXT=20              # Mensajes que ve el LLM por request
MAX_PROPERTIES_PER_RESPONSE=3           # Propiedades máximas por respuesta del bot


# ── Lead Defaults ──────────────────────────────────────────────
DEFAULT_VISIT_DURATION_MINUTES=60       # Duración default si lead no especifica


# ── Lead Qualifier ─────────────────────────────────────────────
QUALIFIER_BOOK_THRESHOLD=75             # Score >= N → activa booking flow
QUALIFIER_QUALIFY_THRESHOLD=40          # Score >= N → agrega pregunta de calificación


# ── Rate Limiting ──────────────────────────────────────────────
# Implementado con middleware custom (no slowapi)
# Configurar aquí para referencia — valores hardcodeados en middleware.py V1
# RATE_LIMIT_PER_TENANT=60    # req/min por tenant
# RATE_LIMIT_PER_IP=120       # req/min por IP (más permisivo — evita bloquear NAT)


# ==============================================================
# CHECKLIST antes de ir a producción:
#
#   [ ] SECRET_KEY generada con openssl rand -hex 32
#   [ ] APP_ENV=production
#   [ ] DATABASE_URL apunta a PostgreSQL (no SQLite)
#   [ ] GROQ_API_KEY configurada
#   [ ] GEMINI_API_KEY configurada (fallback)
#   [ ] SMTP_USER + SMTP_PASSWORD configurados
#   [ ] WHATSAPP_TOKEN configurado (si plan Pro)
#   [ ] credentials.json de Google Calendar en el path correcto
#   [ ] .env NO en el repositorio (verificar .gitignore)
# ==============================================================
